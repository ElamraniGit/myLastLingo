# LinguaLearn — environment configuration example
# Copy to `.env` (backend) and set values as needed. None are required for a
# default localhost setup; override only when deploying to a LAN/phone.

# ── Backend ──────────────────────────────────────────────────────────────────
# Host/port the FastAPI server binds to.
LINGUALEARN_HOST=127.0.0.1
LINGUALEARN_PORT=8080

# SQLite database location (relative to project root).
LINGUALEARN_DB_PATH=data/lingualearn.db

# Logging
LINGUALEARN_LOG_LEVEL=INFO
LINGUALEARN_DEBUG=false

# Whisper model (tiny|base|small|medium|large) — only used if faster-whisper installed.
LINGUALEARN_WHISPER_MODEL=base

# ── Frontend (Next.js) ───────────────────────────────────────────────────────
# Put this in frontend/.env.local. Point it at the backend's /api/v1.
# For phone/LAN access use your machine's IP, e.g. http://192.168.1.50:8080/api/v1
# and ALSO add that origin to _ALLOWED_ORIGINS in backend/main.py (CORS).
NEXT_PUBLIC_API_URL=http://127.0.0.1:8080/api/v1

# ── Notes ────────────────────────────────────────────────────────────────────
# • The Groq AI key is NOT set here — each user enters their own key in-app
#   (stored per-user in the database). Get a free key: https://console.groq.com/keys
# • Secrets (data/.secret_key) are generated automatically on first run.
